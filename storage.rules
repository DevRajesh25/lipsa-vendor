rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Product images
    match /products/{vendorId}/{fileName} {
      allow read: if true; // Public read
      allow write: if request.auth != null && request.auth.uid == vendorId;
    }
    
    // Store logos
    match /logos/{vendorId}/{fileName} {
      allow read: if true; // Public read
      allow write: if request.auth != null && request.auth.uid == vendorId;
    }
  }
}
