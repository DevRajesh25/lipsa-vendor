rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is a vendor (exists in vendors collection)
    function isVendor() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/vendors/$(request.auth.uid));
    }
    
    // Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ============================================
    // VENDORS COLLECTION
    // ============================================
    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(vendorId);
      allow update: if isOwner(vendorId);
      allow delete: if isOwner(vendorId);
    }
    
    // ============================================
    // PRODUCTS COLLECTION
    // ============================================
    match /products/{productId} {
      // Public can read all products
      allow read: if true;
      
      // Vendors can create/update/delete their own products
      allow create: if isVendor() && 
                       request.resource.data.vendorId == request.auth.uid;
      allow update: if isVendor() && resource.data.vendorId == request.auth.uid;
      allow delete: if isVendor() && resource.data.vendorId == request.auth.uid;
      
      // Allow server-side inventory updates (for order processing)
      allow update: if request.auth == null && 
                       'stock' in request.resource.data.diff(resource.data).affectedKeys();
    }
    
    // ============================================
    // ORDERS COLLECTION
    // ============================================
    match /orders/{orderId} {
      // Allow authenticated users to read orders they're involved in
      allow read: if isAuthenticated();
      
      // Allow customers to create orders
      allow create: if isAuthenticated();
      
      // Allow server-side order creation (for API routes)
      allow create: if request.auth == null;
      
      // Allow order updates
      allow update: if isAuthenticated();
      
      // Allow server-side order updates (for status changes)
      allow update: if request.auth == null;
      
      allow delete: if isAuthenticated();
    }
    
    // ============================================
    // CATEGORIES COLLECTION
    // ============================================
    match /categories/{categoryId} {
      // Public can read categories
      allow read: if true;
      
      // Authenticated users can write categories (for testing)
      allow write: if isAuthenticated();
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      // Vendors can read their own notifications
      allow read: if isAuthenticated() && resource.data.vendorId == request.auth.uid;
      
      // Allow creation of notifications
      allow create: if isAuthenticated();
      
      // Allow server-side notification creation
      allow create: if request.auth == null;
      
      // Vendors can update their notifications
      allow update: if isAuthenticated() && resource.data.vendorId == request.auth.uid;
      
      allow write: if isAuthenticated();
    }
    
    // ============================================
    // USERS COLLECTION (for customers)
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // ============================================
    // OTHER COLLECTIONS
    // ============================================
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /returns/{returnId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /payoutRequests/{payoutId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /carts/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
    
    match /influencerVideos/{videoId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /addresses/{addressId} {
      allow read, write: if isAuthenticated();
    }
    
    match /wishlists/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
    
    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /inventory/{inventoryId} {
      allow read, write: if isAuthenticated();
    }
    
    match /shippingRates/{rateId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /taxRates/{rateId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /analytics/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /admins/{adminId} {
      allow read, write: if isAuthenticated();
    }
    
    match /auditLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if true;
    }
  }
}